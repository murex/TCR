# Required because @ng-bootstrap/ng-bootstrap@20 declares a peer dep on @angular/common@^21,
# but this project uses Angular 22. Remove once @ng-bootstrap releases a v21.
legacy-peer-deps=true

# Optional: Suppress the npm update notifier
update-notifier=false

# Optional: Set the registry (default npm registry)
registry=https://registry.npmjs.org/

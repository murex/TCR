{
  "name": "tcr",
  "version": "1.5.0",
  "description": "TCR Web Application",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build-prod": "ng build --output-path ../src/http/static/webapp --configuration production --extract-licenses false",
    "watch": "ng build --watch --configuration development",
    "postinstall": "echo 'Note: --legacy-peer-deps is required because @ng-bootstrap/ng-bootstrap@20 does not yet support Angular 22'",
    "test": "vitest run --config vitest.config.mjs",
    "coverage": "vitest run --coverage --config vitest.config.mjs",
    "test-watch": "vitest --config vitest.config.mjs",
    "lint": "ng lint",
    "clean": "rm -rf node_modules ../src/http/static/webapp",
    "reinstall": "npm run clean && npm install",
    "rebuild": "npm run reinstall && npm run build",
    "rebuild-prod": "npm run reinstall && npm run build-prod"
  },
  "private": true,
  "engines": {
    "npm": ">=10.8.1",
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@fortawesome/angular-fontawesome": "^5.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@popperjs/core": "^2.11.8",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ansicolor": "^2.0.3",
    "bootstrap": "^5.3.8",
    "ng-terminal": "^6.6.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/schematics": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/localize": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@types/jasmine": "~6.0.0",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.60.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "angular-eslint": "^22.0.0",
    "eslint": "^10.4.1",
    "jasmine": "^6.3.0",
    "happy-dom": "^20.10.2",
    "ng-mocks": "^14.15.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}

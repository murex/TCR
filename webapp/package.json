{
  "name": "tcr",
  "version": "1.5.0",
  "description": "TCR Web Application",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build-prod": "ng build --output-path ../src/http/static/webapp --configuration production --extract-licenses false",
    "watch": "ng build --watch --configuration development",
    "postinstall": "echo 'Note: This project requires --legacy-peer-deps flag for npm operations due to Angular 21 compatibility'",
    "test": "vitest run --config vitest.config.mjs",
    "coverage": "vitest run --coverage --config vitest.config.mjs",
    "test-watch": "vitest --config vitest.config.mjs",
    "lint": "ng lint",
    "clean": "rm -rf node_modules ../src/http/static/webapp",
    "reinstall": "npm run clean && npm install",
    "rebuild": "npm run reinstall && npm run build",
    "rebuild-prod": "npm run reinstall && npm run build-prod"
  },
  "private": true,
  "engines": {
    "npm": ">=10.8.1",
    "node": ">=22.5.1"
  },
  "dependencies": {
    "@angular/animations": "^21.2.10",
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.10",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/platform-browser": "^21.2.9",
    "@angular/platform-browser-dynamic": "^21.2.9",
    "@angular/router": "^21.2.10",
    "@fortawesome/angular-fontawesome": "^4.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@popperjs/core": "^2.11.8",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ansicolor": "^2.0.3",
    "bootstrap": "^5.3.8",
    "ng-terminal": "^6.6.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.7",
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/schematics": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.10",
    "@angular/localize": "^21.2.9",
    "@eslint/js": "^10.0.1",
    "@types/jasmine": "~6.0.0",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.2.1",
    "jasmine": "^6.2.0",
    "happy-dom": "^20.9.0",
    "ng-mocks": "^14.15.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
